# Deployer wallet private key (without 0x prefix)
# WARNING: Never commit this file. It is gitignored.
DEPLOYER_PRIVATE_KEY=your_private_key_here

# Base Sepolia RPC URL (default: https://sepolia.base.org)
# You can get a faster private RPC from Alchemy or Infura.
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Base Mainnet RPC URL (for future production use)
BASE_MAINNET_RPC_URL=https://mainnet.base.org

# Basescan API key for contract verification (optional)
# Get one at: https://basescan.org/myapikey
BASESCAN_API_KEY=your_basescan_api_key_here
